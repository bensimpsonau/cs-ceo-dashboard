<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta http-equiv="x-ua-compatible" content="ie=edge">
<link rel="preconnect" href="https://fonts.googleapis.com">
<title>Lead Magnet + TOF Funnel Strategy - Collective Shift</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Barlow:wght@300;400;500;600;700&family=Source+Code+Pro:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --orange: #f59e0b;
  --orange-dim: rgba(245,158,11,0.12);
  --green: #059E78;
  --green-dim: rgba(5,158,120,0.10);
  --purple: #6C63FF;
  --purple-dim: rgba(108,99,255,0.10);
  --red: #EF4444;
  --red-dim: rgba(239,68,68,0.10);
  --blue: #3B82F6;
  --blue-dim: rgba(59,130,246,0.10);
  --bg: #0d0d0d;
  --card: #141418;
  --card-raised: #1a1a20;
  --border: rgba(255,255,255,0.07);
  --border-light: rgba(255,255,255,0.12);
  --text: #e2e2ea;
  --text-muted: #8888a0;
  --text-dim: rgba(255,255,255,0.30);
  --radius: 10px;
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'Barlow',sans-serif;font-size:14px;line-height:1.65;color:var(--text);background:var(--bg);}

/* SECTION NAV - sticky pill bar */
.section-nav{position:sticky;top:0;z-index:200;background:var(--bg);border-bottom:1px solid var(--border);padding:0 16px;display:flex;gap:4px;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;white-space:nowrap;}
.section-nav::-webkit-scrollbar{display:none;}
.section-nav a{display:inline-block;padding:10px 14px;font-size:11px;font-weight:600;font-family:'Plus Jakarta Sans',sans-serif;color:#64748b;text-decoration:none;border-bottom:2px solid transparent;transition:color .2s,border-color .2s;white-space:nowrap;letter-spacing:.03em;}
.section-nav a:hover{color:var(--orange);}
.section-nav a.active{color:var(--orange);border-bottom-color:var(--orange);}

/* TOPBAR */
.topbar{background:#111114;border-bottom:1px solid var(--border);padding:10px 32px;display:flex;align-items:center;justify-content:space-between;}
.topbar-brand{display:flex;align-items:center;gap:8px;text-decoration:none;}
.topbar-icon{width:26px;height:26px;border-radius:6px;background:var(--orange-dim);display:flex;align-items:center;justify-content:center;color:var(--orange);font-weight:800;font-size:10px;font-family:'Plus Jakarta Sans',sans-serif;}
.topbar-text{font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:13px;color:#fff;}
.topbar-links{display:flex;gap:6px;}
.topbar-link{font-family:'Source Code Pro',monospace;font-size:10px;color:var(--text-muted);text-decoration:none;padding:4px 10px;border-radius:5px;border:1px solid var(--border);transition:all .15s;}
.topbar-link:hover{color:#fff;border-color:var(--orange);}
.print-btn{font-family:'Plus Jakarta Sans',sans-serif;font-weight:600;font-size:11px;background:var(--orange);color:#000;border:none;border-radius:5px;padding:4px 12px;cursor:pointer;}

/* DOCUMENT */
.document{max-width:920px;margin:0 auto;padding:32px 40px 80px;}

/* HEADER */
.doc-header{margin-bottom:40px;padding-bottom:28px;border-bottom:1px solid var(--border);}
.doc-tag{font-family:'Source Code Pro',monospace;font-size:10px;font-weight:600;color:var(--orange);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:10px;}
.doc-title{font-family:'Plus Jakarta Sans',sans-serif;font-size:28px;font-weight:800;color:#fff;line-height:1.2;margin-bottom:10px;}
.doc-title span{color:var(--orange);}
.doc-sub{font-size:14px;color:var(--text-muted);line-height:1.65;max-width:700px;}
.doc-meta{display:flex;gap:20px;margin-top:14px;font-size:11px;color:var(--text-muted);font-family:'Source Code Pro',monospace;flex-wrap:wrap;}
.doc-meta strong{color:var(--text);}

/* SECTIONS */
.section{margin-bottom:56px;scroll-margin-top:80px;}
.section-label{font-family:'Plus Jakarta Sans',sans-serif;font-size:10px;font-weight:700;color:var(--orange);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:6px;}
.section-title{font-family:'Plus Jakarta Sans',sans-serif;font-size:22px;font-weight:800;color:#fff;margin-bottom:6px;}
.section-intro{font-size:13px;color:var(--text-muted);max-width:750px;line-height:1.7;margin-bottom:24px;}

/* CARDS */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;margin-bottom:16px;}
.card-title{font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;font-weight:700;color:#fff;margin-bottom:10px;}
.card-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px;}
.card-grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:16px;}

/* CALLOUTS */
.callout{border-left:3px solid var(--orange);background:rgba(245,158,11,0.04);padding:14px 18px;border-radius:0 var(--radius) var(--radius) 0;margin-bottom:16px;font-size:13px;color:var(--text);line-height:1.7;}
.callout strong{color:var(--orange);}
.callout-green{border-left-color:var(--green);background:rgba(5,158,120,0.04);}
.callout-green strong{color:var(--green);}
.callout-purple{border-left-color:var(--purple);background:rgba(108,99,255,0.04);}
.callout-purple strong{color:var(--purple);}

/* TAGS */
.tag{display:inline-block;font-family:'Source Code Pro',monospace;font-size:9px;font-weight:700;padding:2px 8px;border-radius:4px;letter-spacing:.5px;text-transform:uppercase;}
.tag-orange{background:var(--orange-dim);color:var(--orange);}
.tag-green{background:var(--green-dim);color:var(--green);}
.tag-purple{background:var(--purple-dim);color:var(--purple);}
.tag-red{background:var(--red-dim);color:var(--red);}
.tag-blue{background:var(--blue-dim);color:var(--blue);}

/* TABLES */
table{width:100%;border-collapse:collapse;font-size:12.5px;margin:10px 0;}
th{font-family:'Plus Jakarta Sans',sans-serif;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--orange);padding:10px 12px;text-align:left;border-bottom:2px solid var(--border);background:rgba(245,158,11,0.04);}
td{padding:10px 12px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:top;line-height:1.55;}
tr:last-child td{border-bottom:none;}

/* STAT BARS */
.stats-bar{display:flex;gap:1px;background:var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:20px;}
.stat{flex:1;background:var(--card);padding:14px 10px;text-align:center;}
.stat-label{font-family:'Source Code Pro',monospace;font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);margin-bottom:3px;}
.stat-value{font-family:'Plus Jakarta Sans',sans-serif;font-size:17px;font-weight:800;color:var(--orange);}
.stat-value.white{color:#fff;font-size:13px;font-weight:700;}
.stat-value.green{color:var(--green);}

/* PILL CHAIN (funnel visualization) */
.pill-chain{display:flex;align-items:center;gap:0;flex-wrap:wrap;margin:12px 0 16px;}
.pill{padding:7px 14px;font-size:11px;font-weight:600;font-family:'Plus Jakarta Sans',sans-serif;border-radius:20px;white-space:nowrap;}
.pill-arrow{color:var(--text-dim);font-size:14px;padding:0 4px;}

/* DM BUBBLE - ManyChat message style */
.dm-bubble{background:#1e1e2a;border:1px solid var(--border-light);border-radius:14px 14px 14px 4px;padding:14px 18px;margin:10px 0;max-width:520px;position:relative;}
.dm-bubble::before{content:'';position:absolute;bottom:0;left:-6px;width:12px;height:12px;background:#1e1e2a;border-bottom-right-radius:12px;border:1px solid var(--border-light);border-top:none;border-left:none;clip-path:polygon(100% 0,100% 100%,0 100%);}
.dm-label{font-family:'Source Code Pro',monospace;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;display:flex;align-items:center;gap:8px;}
.dm-time{font-family:'Source Code Pro',monospace;font-size:9px;color:var(--text-dim);font-weight:400;}
.dm-text{font-size:13px;color:var(--text);line-height:1.65;}
.dm-text a,.dm-text .dm-link{color:var(--orange);font-weight:600;text-decoration:none;}
.dm-text .dm-note{font-size:11px;color:var(--text-muted);margin-top:6px;}
.dm-buttons{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;}
.dm-btn{padding:6px 14px;border-radius:18px;font-size:11px;font-weight:600;font-family:'Plus Jakarta Sans',sans-serif;border:1px solid var(--border-light);color:var(--text);background:rgba(255,255,255,0.04);cursor:default;}

/* EMAIL CARD */
.email-card{background:#fff;border-radius:var(--radius);padding:20px 24px;margin:12px 0;max-width:560px;color:#1a1a1a;position:relative;box-shadow:0 2px 12px rgba(0,0,0,0.3);}
.email-meta{display:flex;align-items:center;gap:8px;margin-bottom:10px;font-size:10px;color:#888;font-family:'Source Code Pro',monospace;}
.email-day-tag{background:#f59e0b;color:#000;font-weight:700;padding:2px 8px;border-radius:4px;font-size:9px;text-transform:uppercase;letter-spacing:.5px;}
.email-subject{font-family:'Plus Jakarta Sans',sans-serif;font-size:15px;font-weight:700;color:#111;margin-bottom:2px;}
.email-preview{font-size:12px;color:#666;margin-bottom:10px;font-style:italic;}
.email-body{font-size:13px;color:#333;line-height:1.65;margin-bottom:12px;}
.email-cta{display:inline-block;background:#f59e0b;color:#000;font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 20px;border-radius:6px;text-decoration:none;}

/* KPI TABLE - green targets */
.kpi-table td.target{color:var(--green);font-weight:600;}

/* LEAD MAGNET BLOCK */
.lm-block{border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:28px;}
.lm-header{padding:16px 20px;display:flex;align-items:center;gap:14px;}
.lm-header-icon{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.lm-header-text{flex:1;}
.lm-header-keyword{font-family:'Source Code Pro',monospace;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;}
.lm-header-title{font-family:'Plus Jakarta Sans',sans-serif;font-size:16px;font-weight:800;color:#fff;margin-top:2px;}
.lm-body{padding:20px;background:var(--card);}
.lm-section-title{font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;font-weight:700;color:var(--orange);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;margin-top:18px;}
.lm-section-title:first-child{margin-top:0;}

/* SPLIT TEST */
.split-test{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:10px 0 16px;}
.split-variant{background:var(--card-raised);border:1px solid var(--border);border-radius:8px;padding:14px 16px;}
.split-label{font-family:'Source Code Pro',monospace;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;}
.split-copy{font-size:12.5px;color:var(--text);line-height:1.6;}
.split-hypothesis{font-size:11px;color:var(--text-muted);margin-top:8px;font-style:italic;border-top:1px solid var(--border);padding-top:8px;}

/* FLOW DIAGRAM */
.flow{display:flex;flex-direction:column;align-items:center;gap:0;margin:14px 0;}
.flow-step{width:100%;max-width:580px;padding:12px 18px;border-radius:8px;border:1px solid var(--border);background:var(--card);font-size:12.5px;}
.flow-step-label{font-family:'Source Code Pro',monospace;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;}
.flow-arrow{text-align:center;font-size:13px;color:var(--text-dim);padding:3px 0;}

/* JUMP BUTTONS */
.jump-row{display:flex;flex-wrap:wrap;gap:6px;margin:12px 0;}
.jump-btn{display:inline-block;padding:6px 14px;border-radius:6px;font-size:11px;font-weight:600;font-family:'Plus Jakarta Sans',sans-serif;background:var(--card-raised);border:1px solid var(--border);color:var(--text-muted);text-decoration:none;transition:all .15s;}
.jump-btn:hover{color:var(--orange);border-color:var(--orange);}

/* AD TYPE CARD */
.ad-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:14px;}
.ad-card-title{font-family:'Plus Jakarta Sans',sans-serif;font-size:13px;font-weight:700;color:#fff;margin-bottom:8px;display:flex;align-items:center;gap:8px;}

/* CHECKLIST */
.checklist{list-style:none;padding:0;}
.checklist li{position:relative;padding:3px 0 3px 22px;font-size:12.5px;}
.checklist li::before{content:"\2713";position:absolute;left:0;color:var(--green);font-weight:700;}

/* DIVIDER */
hr.divider{border:none;border-top:1px solid var(--border);margin:36px 0;}

/* OVERVIEW GRID */
.overview-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;}
.overview-mini-card{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:14px 16px;}
.overview-mini-title{font-family:'Plus Jakarta Sans',sans-serif;font-size:11px;font-weight:700;color:var(--orange);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;}
.overview-item{font-size:12px;color:var(--text);padding:3px 0;display:flex;gap:8px;align-items:baseline;}
.overview-item .kw{font-family:'Source Code Pro',monospace;font-size:10px;font-weight:700;color:var(--orange);min-width:72px;}

/* MOBILE */
@media(max-width:768px){
  body{overflow-x:hidden;}
  .topbar{flex-wrap:wrap;gap:6px;padding:8px 12px;}
  .topbar-link{font-size:10px;padding:4px 8px;}
  .print-btn{display:none;}
  .section-nav{padding:0 8px;}
  .section-nav a{padding:8px 8px;font-size:10px;}
  .doc-title{font-size:22px;}
  .section-title{font-size:18px;}
  .document{padding:20px 16px 60px;}
  .card-grid-2,.card-grid-3,.overview-grid,.split-test{display:block!important;}
  .card-grid-2>*,.card-grid-3>*,.overview-grid>*,.split-test>*{margin-bottom:10px;}
  .stats-bar{flex-direction:column;gap:1px;}
  .pill-chain{gap:2px;}
  .pill{font-size:10px;padding:5px 10px;}
  table{display:block;overflow-x:auto;-webkit-overflow-scrolling:touch;}
  .dm-bubble{max-width:100%;}
  .email-card{max-width:100%;}
  h1{font-size:20px!important;}
  h2{font-size:17px!important;}
}
@media(max-width:480px){
  .document{padding:16px 12px 50px;}
  .pill-chain{flex-direction:column;align-items:flex-start;}
  .pill-arrow{transform:rotate(90deg);}
}

/* PRINT */
@media print{
  .topbar,.section-nav{display:none!important;}
  body{background:#fff;color:#1a1a1a;font-size:11px;}
  .document{padding:20px;max-width:100%;}
  .card,.callout,.stat,.lm-body,.lm-header,.dm-bubble,.ad-card{background:#fafafa;border-color:#ddd;}
  .doc-title,.section-title,.card-title,.lm-header-title{color:#1a1a1a;}
  .stat-value,.stat-value.white{color:#1a1a1a;}
  th{background:#f0f0f0;color:#1a1a1a;}
  td,.callout,.section-intro{color:#333;}
  .section{page-break-inside:avoid;}
}
</style>
</head>
<body>
<div id="pageLoader" style="position:fixed;inset:0;background:#0d0d0d;z-index:9999;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px;">
  <div style="width:40px;height:40px;border:3px solid rgba(245,158,11,0.2);border-top-color:#f59e0b;border-radius:50%;animation:spin 0.8s linear infinite;"></div>
  <div style="color:#8888a0;font-size:13px;font-family:sans-serif;">Loading strategy...</div>
</div>
<style>@keyframes spin{to{transform:rotate(360deg)}}</style>

<!-- SECTION NAV -->
<nav class="section-nav" id="sectionNav"></nav>

<!-- TOP BAR -->
<div class="topbar">
  <a href="index.html" class="topbar-brand">
    <div class="topbar-icon">CS</div>
    <div class="topbar-text">Collective Shift</div>
  </a>
  <div class="topbar-links">
    <a href="cs-marketing-plan-april-2026.html" class="topbar-link">Marketing OS</a>
    <a href="digital-asset-shift-newsletter.html" class="topbar-link">Newsletter</a>
    <a href="index.html" class="topbar-link">Dashboard</a>
    <button class="print-btn" onclick="window.print();">Print / PDF</button>
  </div>
</div>

<!-- DOCUMENT -->
<div class="document">

<!-- HEADER -->
<div class="doc-header">
  <div class="doc-tag">Confidential / Leadership + Marketing Team</div>
  <h1 class="doc-title">Lead Magnet + <span>TOF Funnel Strategy</span></h1>
  <p class="doc-sub">The unified playbook for driving Platinum sales through organic ManyChat flows and paid Meta Ads. Both channels feed the same funnel: cold audience to lead magnet to email nurture to setter call to Platinum $14,999. Lead magnets are qualification tools, not just list builders. Built on Jeremy Haynes' Hand Raiser formula, Venus Fly Trap sequencing, and Call Funnel Blueprint.</p>
  <div class="doc-meta">
    <div><strong>Prepared for:</strong> Ben Simpson + Marketing Team</div>
    <div><strong>Date:</strong> 3 April 2026</div>
    <div><strong>Version:</strong> <span class="tag tag-orange">v6.0 / Real ICP Data + Micro Magnet Framework</span></div>
  </div>
</div>


<!-- =========================================== -->
<!-- SECTION 0: ONE-PAGE OVERVIEW                -->
<!-- =========================================== -->
<div class="section" id="s00">
  <div class="section-label">00 / Executive Overview</div>
  <h2 class="section-title">Strategy at a Glance</h2>

  <!-- Funnel pill chain -->
  <div class="card" style="border-top:3px solid var(--orange);padding:16px 20px;">
    <div style="font-family:'Plus Jakarta Sans',sans-serif;font-size:10px;font-weight:700;color:var(--orange);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">The funnel in 6 steps</div>
    <div class="pill-chain">
      <div class="pill" style="background:var(--purple-dim);color:var(--purple);">Cold Audience</div>
      <div class="pill-arrow">&#8594;</div>
      <div class="pill" style="background:var(--orange-dim);color:var(--orange);">TOF Ad or Organic Reel</div>
      <div class="pill-arrow">&#8594;</div>
      <div class="pill" style="background:var(--green-dim);color:var(--green);">Lead Magnet</div>
      <div class="pill-arrow">&#8594;</div>
      <div class="pill" style="background:var(--blue-dim);color:var(--blue);">14-Day Email Nurture</div>
      <div class="pill-arrow">&#8594;</div>
      <div class="pill" style="background:var(--orange-dim);color:var(--orange);">Setter Call</div>
      <div class="pill-arrow">&#8594;</div>
      <div class="pill" style="background:var(--green);color:#000;font-weight:700;">Platinum $14,999</div>
    </div>
  </div>

  <!-- THE FRAMEWORK SHIFT -->
  <div class="card" style="border-top:3px solid var(--orange);margin-bottom:16px;" id="s00b">
    <div style="font-family:'Plus Jakarta Sans',sans-serif;font-size:10px;font-weight:700;color:var(--orange);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;">The Framework Shift - Micro Magnets</div>
    <div class="card-grid-2" style="margin-bottom:0;">
      <div style="padding:14px 16px;background:rgba(239,68,68,0.04);border:1px solid rgba(239,68,68,0.15);border-radius:8px;">
        <div style="font-size:12px;font-weight:800;color:var(--red);margin-bottom:8px;">&#10060; OLD THINKING</div>
        <div style="font-size:12px;color:var(--text-muted);line-height:1.7;">
          &#8226; 8-page PDF report<br>
          &#8226; 12-page strategy guide<br>
          &#8226; 30-minute audit<br>
          &#8226; Information-packed<br>
          <div style="font-size:11px;color:var(--text-dim);margin-top:8px;font-style:italic;">"Here's a lot of valuable information"</div>
        </div>
      </div>
      <div style="padding:14px 16px;background:rgba(5,158,120,0.04);border:1px solid rgba(5,158,120,0.15);border-radius:8px;">
        <div style="font-size:12px;font-weight:800;color:var(--green);margin-bottom:8px;">&#9989; NEW THINKING (Taki Framework)</div>
        <div style="font-size:12px;color:var(--text-muted);line-height:1.7;">
          &#8226; Calculator giving your number in 60 seconds<br>
          &#8226; Quiz outputting your personal strategy<br>
          &#8226; 1-page steal-this checklist<br>
          &#8226; Custom GPT giving instant output<br>
          <div style="font-size:11px;color:var(--text-dim);margin-top:8px;font-style:italic;">"Here's your result - steal it and use it now"</div>
        </div>
      </div>
    </div>
    <div class="callout" style="margin-top:16px;margin-bottom:0;border-left-color:var(--orange);background:rgba(245,158,11,0.06);">
      <strong>Key principle:</strong> The ICP doesn't want more content. They want less. Not information - results. Busy, successful people want to steal your tool and get a result in 3 minutes.
    </div>
  </div>

  <!-- 2-col: 8 Micro Magnets + Traffic Sources -->
  <div class="overview-grid">
    <div class="overview-mini-card">
      <div class="overview-mini-title">10 Micro Magnets (4 Categories)</div>
      <div style="font-size:11px;font-weight:600;color:var(--red);margin-bottom:4px;margin-top:4px;">&#128293; ICP Pain-Point Magnets (data-driven priority)</div>
      <div class="overview-item"><span class="kw" style="color:var(--red);">EXIT</span> The Profit Exit Blueprint <span class="tag tag-red" style="font-size:7px;margin-left:4px;">NEW &mdash; #1 PAIN</span></div>
      <div class="overview-item"><span class="kw" style="color:var(--red);">FILTER</span> The Noise Filter <span class="tag tag-red" style="font-size:7px;margin-left:4px;">NEW &mdash; #2 PAIN</span></div>
      <div style="font-size:11px;font-weight:600;color:var(--orange);margin-bottom:4px;margin-top:8px;">&#9889; Instant Calculators (&lt;60 seconds)</div>
