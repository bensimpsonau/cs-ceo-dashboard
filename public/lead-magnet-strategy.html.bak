<!-- SECTION 3: ORGANIC MANYCHAT FLOWS           -->
<!-- =========================================== -->
<div class="section" id="s03">
  <div class="section-label">03 / Organic ManyChat Flows</div>
  <h2 class="section-title">7 Keywords, 4 Messages Each, Verbatim</h2>
  <p class="section-intro">For each keyword, the full DM sequence delivered via ManyChat. Trigger: comment the keyword on any Reel. All copy is in Ben's voice. No em dashes. "Digital assets" not "crypto". No hype. No guaranteed returns. Every message moves the lead one step closer to the setter call.</p>

  <!-- KEYWORD REFERENCE TABLE -->
  <div class="card" style="border-top:3px solid var(--orange);margin-bottom:28px;">
    <div class="card-title">ManyChat Keywords &mdash; Full List</div>
    <table style="font-size:12px;">
